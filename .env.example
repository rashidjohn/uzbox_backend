# ── Django ─────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development

# ── Database (production da) ────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/uzbox

# ── Frontend URL (email verify uchun) ──────────────────────
FRONTEND_URL=http://localhost:3000

# ── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (SendGrid) ────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_key
DEFAULT_FROM_EMAIL=noreply@uzbox.uz

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ── CORS (production) ───────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://uzbox.uz,https://www.uzbox.uz

# ── Sentry (production monitoring) ─────────────────────────
SENTRY_DSN=your_sentry_dsn
